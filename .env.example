# Required only for providers that need API keys.
# Copy this file to .env and fill in the values you need.
# .env is in .gitignore — never commit your actual keys.

# For provider: anthropic-direct
# Also used as a fallback for the claude-agent-sdk provider when OAuth (via
# Claude Code login) isn't available.
ANTHROPIC_API_KEY=

# For provider: openai
OPENAI_API_KEY=

# For provider: openrouter
OPENROUTER_API_KEY=

# For provider: amp (Sourcegraph Amp)
AMP_API_KEY=

# For the agent's `web_search` tool — Tavily (https://tavily.com).
# Free tier: 1000 searches/month, no card required.
# Without this key, web_search returns an explicit "not configured" error
# rather than silently failing.
TAVILY_API_KEY=

# Knowledge-base connector secrets — only required for the connectors you
# actually configure under knowledgeBase.projects[*] in ~/.strata/config.json.
# Connectors throw at construction when their PAT is missing (fail-fast).
STASH_PAT=
JIRA_PAT=
CONFLUENCE_PAT=
