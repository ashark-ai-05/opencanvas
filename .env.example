# Required only for providers that need API keys.
# Copy this file to .env and fill in the values you need.
# .env is in .gitignore — never commit your actual keys.

# For provider: anthropic-direct
ANTHROPIC_API_KEY=

# For provider: openai
OPENAI_API_KEY=

# For provider: openrouter
OPENROUTER_API_KEY=

# For provider: amp (stub — real wiring deferred)
AMP_API_KEY=

# Claude Agent SDK uses OAuth via Claude Code — no env var needed.
# If you want to use an API key instead of OAuth with claude-agent-sdk,
# set ANTHROPIC_API_KEY above.

# For the agent's `web_search` tool — Tavily (https://tavily.com).
# Free tier: 1000 searches/month, no card required.
# Without this key, web_search returns empty results (the agent falls back
# to KB-only or apologizes).
TAVILY_API_KEY=
